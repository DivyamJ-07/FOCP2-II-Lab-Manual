//Code to convert Celsius to Fahrenheit using OOPS concept
#include <iostream>
using namespace std;

class Temperature {
private:
    float celsius;

public:
    void inputTemperature() {
        cout << "Enter temperature in Celsius: ";
        cin >> celsius;
    }

    float convertToFahrenheit() {
        return (celsius * 9.0 / 5.0) + 32.0;
    }

    void displayResult() {
        cout << "Celsius: " << celsius << "°C" << endl;
        cout << "Fahrenheit: " << convertToFahrenheit() << "°F" << endl;
    }
};

int main() {
    Temperature temp;
    temp.inputTemperature();
    temp.displayResult();
    return 0;
}
