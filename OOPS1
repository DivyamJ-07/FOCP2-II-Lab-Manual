//Code to Store and display student details along with total marks using OOPS concept
#include<iostream>
using namespace std;
class Student{
    string name;
    int rollNo;
    int marks1;
    int marks2;
    int marks3;
    int total;
public:
void inputDetails(){
    cout<<"Enter Roll Number, Name, Marks sub1, Marks sub2, Marks sub3"<<endl;
    cin>>rollNo>>name>>marks1>>marks2>>marks3;
}
int calculateTotal(){
    total=0;
    total= marks1+marks2+marks3;
    return total;
}
void displayDetails(){
    cout<<"Roll Number: "<<rollNo<<endl<<"Name: "<<name<<endl<<"Marks of sub1: "<<marks1<<endl<<"Marks of sub2: "<<marks2<<endl<<"Marks of sub3: "<<marks3<<endl<<"Total Marks: "<<total;
}
};
int main(){
    Student S1;
    S1.inputDetails();
    S1.calculateTotal();
    S1.displayDetails();
return 0;
}